/*
 * plane-validation.nqe
 * --------------------
 * Verify that a set of CEs reach each other's loopbacks over the EXPECTED backbone
 * plane during the LDP->SR migration. In network 111 the two backbones are separate
 * ASes (l-* = AS 65010 / LDP, s-* = AS 65020 / SR). A CE opts a prefix into SR by
 * tagging it (community 65020:1) via 'route-map SR-MIGRATE out', gated by membership
 * in 'ip prefix-list MIGRATE-TO-SR-LIST'. The PEs' 'route-map CE-STEER-OUT' then
 * AS-path-prepends the *other* plane so the tagged prefix rides SR (and untagged
 * rides LDP).
 *
 * This query reads the parsed FIB (not config text): for each observer CE it finds
 * the active next-hop toward every other CE's /32 loopback, resolves the egress link,
 * and derives the plane from the far-end PE's name prefix (l-* / s-*). A violation is
 * a loopback reached over a plane != targetPlane.
 *
 * Parameters:
 *   targetPlane : "s-plane" | "l-plane"  — the plane these CEs are expected to use
 *   targetCE    : List<String>           — CE device names to cross-check
 *   Match       : Bool                   — true = emit violations; false = report-only
 *
 * Run (net 111, payment CEs expected on SR):
 *   run_query.py --network-id 111 --query-file nqe/plane-validation.nqe \
 *     --params-json '{"targetPlane":"s-plane",
 *                     "targetCE":["ny-dc-ce","lon-dc-ce","la-br-ce"],
 *                     "Match":true}'
 *
 * NOTE (network 111, snapshot 187): with the payment CE set above this returns 2
 * violations — la-br-ce's loopback 10.0.0.20/32 is reached over the l-plane from both
 * ny-dc-ce (via l-pe-ny) and lon-dc-ce (via l-pe-lon), i.e. activePlane=l-plane vs
 * expectedPlane=s-plane. Root cause: la-br-ce's MIGRATE-TO-SR-LIST is empty, so its
 * prefixes never get community 65020:1 and the PEs steer them onto LDP. The reverse
 * direction (la-br -> DC) correctly rides s-plane (the 4 non-violation rows). Fix: add
 * la-br's loopback + payment subnet to MIGRATE-TO-SR-LIST on la-br-ce.
 */
@query query(targetPlane: String, targetCE: List<String>, Match: Bool) =
  foreach ownerDev in network.devices
  where ownerDev.name in targetCE
  foreach ownerIntf in ownerDev.interfaces
  where ownerIntf.loopbackMode
  foreach ownerSub in ownerIntf.subinterfaces
  foreach ownerAddr in ownerSub.ipv4.addresses
  foreach observerDev in network.devices
  where observerDev.name in targetCE
  where observerDev.name != ownerDev.name
  foreach ni in observerDev.networkInstances
  where isPresent(ni.afts.ipv4Unicast)
  foreach ipEntry in ni.afts.ipv4Unicast.ipEntries
  where address(ipEntry.prefix) == ownerAddr.ip
  where length(ipEntry.prefix) == 32
  foreach nh in ipEntry.nextHops
  where isPresent(nh.ipAddress)
  foreach egressIntf in observerDev.interfaces
  where egressIntf.name == nh.interfaceName
  foreach l in egressIntf.links
  let plane = if substring(l.deviceName, 0, 2) == "l-"
              then "l-plane"
              else if substring(l.deviceName, 0, 2) == "s-"
                   then "s-plane"
                   else "UNKNOWN"
  select {
    violation: Match && plane != targetPlane,
    migratedCE: ownerDev.name,
    observerCE: observerDev.name,
    prefix: ipEntry.prefix,
    peerPE: l.deviceName,
    activePlane: plane,
    expectedPlane: targetPlane
  };
