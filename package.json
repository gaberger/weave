{
  "name": "weave",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A cooperative-network agent framework — autonomous Claude workers coordinating as peers over a shared substrate.",
  "engines": {
    "node": ">=18.17"
  },
  "bin": {
    "weave": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bin": "bun build src/cli.ts --compile --outfile weave",
    "build:dist": "bun run scripts/build.ts",
    "build:sandbox": "docker build -t weave-sandbox -f sandbox/Dockerfile sandbox",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "test:bun": "bun test ./src/adapters/secondary/bun-sqlite-substrate.bun-test.ts",
    "demo": "bash scripts/demo.sh",
    "weave": "node --import tsx src/cli.ts",
    "demos": "bash demos/run.sh"
  },
  "comments": {
    "dependencies": "claude-agent-sdk + zod are used ONLY by src/adapters/secondary/claude-sdk.ts (the real Worker backend); the domain/ports/usecases and all other adapters have no LLM dependency. better-sqlite3 backs SqliteSubstrate."
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.183",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  }
}
